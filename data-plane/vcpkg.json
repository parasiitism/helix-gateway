{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg/master/scripts/vcpkg.schema.json",
  "name": "helix-gateway",
  "version": "0.1.0",
  "description": "Helix LLM Gateway data plane",
  "homepage": "https://github.com/parasiitism/helix-gateway",
  "license": "Apache-2.0",
  "dependencies": [
    "drogon",
    "spdlog",
    "simdjson"
  ],
  "features": {
    "full": {
      "description": "Build with full feature set (cache, observability, gRPC)",
      "dependencies": [
        "hnswlib",
        "redis-plus-plus",
        "grpc",
        "protobuf",
        "prometheus-cpp",
        "opentelemetry-cpp",
        "boost-asio"
      ]
    },
    "tests": {
      "description": "Build unit tests",
      "dependencies": ["gtest"]
    },
    "benchmarks": {
      "description": "Build microbenchmarks",
      "dependencies": ["benchmark"]
    }
  }
}